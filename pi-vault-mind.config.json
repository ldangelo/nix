{
  "version": 2,
  "collections": {
    "main": {
      "path": "collections/nix.jsonl",
      "schema": [
        "id",
        "domain",
        "source",
        "fact",
        "tag",
        "artifact"
      ]
    },
    "pending": {
      "path": "collections/pending.jsonl",
      "schema": "main"
    },
    "context_events": {
      "path": "collections/context_events.jsonl",
      "schema": [
        "id",
        "type",
        "session_entry_id",
        "content",
        "timestamp",
        "tags"
      ],
      "dedupField": "id"
    }
  },
  "injectors": [
    {
      "name": "draft-context",
      "regex": "draft\\s+(\\S+)",
      "collection": "main",
      "filterField": "tag",
      "artifactPath": "collections/artifact.md"
    }
  ],
  "vaultMind": {
    "dataDir": ".lancedb",
    "ftsEnabled": true,
    "graph": {
      "enabled": true,
      "canvasSync": false
    }
  }
}
